{
  "name": "@diagram-generator/layout-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "npm --prefix ../graph-layout-core run build && npm --prefix ../graph-layout-elk run build",
    "build": "tsc",
    "build:browser": "node build-browser.mjs",
    "export:sequence-svg": "node scripts/export-sequence-svg.mjs",
    "export:svg": "node scripts/export-frame-svg.mjs",
    "pretest": "npm --prefix ../graph-layout-core run build && npm --prefix ../graph-layout-elk run build && npm --prefix ../.. run clean:src-artifacts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@diagram-generator/graph-layout-core": "file:../graph-layout-core",
    "@diagram-generator/graph-layout-elk": "file:../graph-layout-elk",
    "harfbuzzjs": "^1.2.0",
    "yaml": "^2.8.0"
  }
}
